FROM golang:1.26-bookworm AS builder
WORKDIR /src
COPY go.mod ./
RUN go mod download || true
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /modelplane-mock ./cmd/modelplane-mock

FROM registry.access.redhat.com/ubi9/ubi-micro:latest
COPY --from=builder /modelplane-mock /modelplane-mock
USER 65534:65534
EXPOSE 8090
ENTRYPOINT ["/modelplane-mock"]
