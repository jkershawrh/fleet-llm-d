FROM rust:1.90-bookworm AS builder
WORKDIR /src
COPY Cargo.toml ./
COPY Cargo.lock* ./
COPY crates/ crates/
RUN cargo build --release --bin fleet-gateway

FROM registry.access.redhat.com/ubi9/ubi-minimal:latest
RUN microdnf install -y ca-certificates && microdnf clean all
COPY --from=builder /src/target/release/fleet-gateway /fleet-gateway
USER 65534:65534
EXPOSE 8080 8081 9090
LABEL org.opencontainers.image.source="https://github.com/llm-d/fleet-llm-d" \
      org.opencontainers.image.description="fleet-llm-d inference gateway" \
      org.opencontainers.image.licenses="Apache-2.0"
ENTRYPOINT ["/fleet-gateway"]
