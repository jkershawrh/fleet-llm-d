FROM rust:1.79-bookworm AS builder
WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
RUN cargo build --release --bin fleet-gateway

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /src/target/release/fleet-gateway /fleet-gateway
EXPOSE 8080 9090
ENTRYPOINT ["/fleet-gateway"]
