FROM golang:1.26-bookworm AS builder
WORKDIR /src
COPY go.mod ./
RUN go mod download || true
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /fleet-controller ./cmd/fleet-controller

FROM registry.access.redhat.com/ubi9/ubi-micro:latest
COPY --from=builder /fleet-controller /fleet-controller
USER 65534:65534
EXPOSE 8080 9091 9092
LABEL org.opencontainers.image.source="https://github.com/llm-d/fleet-llm-d" \
      org.opencontainers.image.description="fleet-llm-d control plane" \
      org.opencontainers.image.licenses="Apache-2.0"
ENTRYPOINT ["/fleet-controller"]
