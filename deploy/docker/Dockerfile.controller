FROM golang:1.23-bookworm AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /fleet-controller ./cmd/fleet-controller

FROM gcr.io/distroless/static-debian12
COPY --from=builder /fleet-controller /fleet-controller
EXPOSE 8080 9090
ENTRYPOINT ["/fleet-controller"]
