FROM golang:1.26-bookworm AS builder
WORKDIR /src
COPY go.mod ./
COPY cmd/inference-mock/ cmd/inference-mock/
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /inference-mock ./cmd/inference-mock

FROM registry.access.redhat.com/ubi9/ubi-micro:latest
COPY --from=builder /inference-mock /inference-mock
USER 65534:65534
EXPOSE 8000
ENTRYPOINT ["/inference-mock"]
