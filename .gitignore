__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build
/build/
/dist/

# Environment
.env
.env.local
*.pem

# Test harness results (may contain cluster URLs)
test/harness/results/

# Generated
pkg/apis/fleet/v1alpha1/zz_generated.*
api/proto/**/*.pb.go
api/proto/**/*.pb.ts
web/src/lib/api-client.generated.ts
upstream-are-ledger/
upstream-llm-d/
upstream-model-spec/

# Deployment-specific (cluster snapshots, rollback data)
rollback/
deploy/prod-cluster-1/
*.kubeconfig
*-snapshot-*.yaml

# Local model exports (large binaries)
ovms-models*/
ovms-tmp*/

# Internal documentation (not for public repos)
docs/internal/

# Built binaries (use make build)
/fleet-controller
/harness
